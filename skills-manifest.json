{
  "name": "thesis-skills",
  "version": "1.0.0",
  "default_ruleset": "tsinghua-thesis",
  "runner": {
    "check": "run_check_once.py",
    "fix": "run_fix_cycle.py"
  },
  "modules": [
    {"id": "00-bib-zotero", "entry": "00-bib-zotero/THESIS_BIB_ZOTERO.md", "type": "workflow"},
    {"id": "00-bib-endnote", "entry": "00-bib-endnote/THESIS_BIB_ENDNOTE.md", "type": "workflow"},
    {"id": "01-word-to-latex", "entry": "01-word-to-latex/THESIS_WORD_TO_LATEX.md", "type": "workflow", "runner": "01-word-to-latex/migrate_project.py"},
    {"id": "02-latex-to-word", "entry": "02-latex-to-word/THESIS_LATEX_TO_WORD.md", "type": "workflow", "runner": "02-latex-to-word/migrate_project.py"},
    {"id": "03-latex-review-diff", "entry": "03-latex-review-diff/THESIS_REVIEW_DIFF.md", "type": "workflow", "runner": "03-latex-review-diff/review_diff.py"},
    {"id": "04-word-review-ingest", "entry": "04-word-review-ingest/THESIS_WORD_REVIEW_INGEST.md", "type": "workflow", "runner": "04-word-review-ingest/feedback_ingest.py"},
    {"id": "10-check-references", "entry": "10-check-references/THESIS_CHECK_REFERENCES.md", "type": "checker"},
    {"id": "11-check-language", "entry": "11-check-language/THESIS_CHECK_LANGUAGE.md", "type": "checker"},
    {"id": "12-check-format", "entry": "12-check-format/THESIS_CHECK_FORMAT.md", "type": "checker"},
    {"id": "13-check-content", "entry": "13-check-content/THESIS_CHECK_CONTENT.md", "type": "checker"},
    {"id": "14-check-language-deep", "entry": "14-check-language-deep/THESIS_CHECK_LANGUAGE_DEEP.md", "type": "checker"},
    {"id": "15-check-compile", "entry": "15-check-compile/THESIS_CHECK_COMPILE.md", "type": "checker", "runner": "15-check-compile/check_compile.py"},
    {"id": "16-check-readiness", "entry": "16-check-readiness/THESIS_CHECK_READINESS.md", "type": "checker", "runner": "16-check-readiness/check_readiness.py"},
    {"id": "17-defense-pack", "entry": "17-defense-pack/README.md", "type": "workflow", "runners": ["17-defense-pack/generate_outline.py", "17-defense-pack/generate_chapter_highlights.py", "17-defense-pack/generate_figure_inventory.py", "17-defense-pack/generate_candidate_tables_diagrams.py", "17-defense-pack/generate_talk_prep_notes.py"]},
    {"id": "20-fix-references", "entry": "20-fix-references/THESIS_FIX_REFERENCES.md", "type": "fixer"},
    {"id": "21-fix-language-style", "entry": "21-fix-language-style/THESIS_FIX_LANGUAGE_STYLE.md", "type": "fixer"},
    {"id": "22-fix-format-structure", "entry": "22-fix-format-structure/THESIS_FIX_FORMAT_STRUCTURE.md", "type": "fixer"},
    {"id": "24-fix-language-deep", "entry": "24-fix-language-deep/THESIS_FIX_LANGUAGE_DEEP.md", "type": "fixer"},
    {"id": "90-rules", "entry": "90-rules/THESIS_RULE_PACKS.md", "type": "ruleset", "runner": "90-rules/create_pack.py", "draft_runner": "90-rules/create_draft_pack.py", "lint_runner": "90-rules/lint_pack.py"},
    {"id": "99-runner", "entry": "99-runner/README.md", "type": "runner"}
  ]
}
