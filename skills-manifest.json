{
  "name": "thesis-skills",
  "version": "0.2.0-alpha",
  "default_ruleset": "tsinghua-thesis",
  "runner": {
    "check": "run_check_once.py",
    "fix": "run_fix_cycle.py"
  },
  "modules": [
    {"id": "00-bib-zotero", "entry": "00-bib-zotero/THESIS_BIB_ZOTERO.md", "type": "workflow"},
    {"id": "00-bib-endnote", "entry": "00-bib-endnote/THESIS_BIB_ENDNOTE.md", "type": "workflow"},
    {"id": "01-word-to-latex", "entry": "01-word-to-latex/THESIS_WORD_TO_LATEX.md", "type": "workflow", "runner": "01-word-to-latex/migrate_project.py"},
    {"id": "10-check-references", "entry": "10-check-references/THESIS_CHECK_REFERENCES.md", "type": "checker"},
    {"id": "11-check-language", "entry": "11-check-language/THESIS_CHECK_LANGUAGE.md", "type": "checker"},
    {"id": "12-check-format", "entry": "12-check-format/THESIS_CHECK_FORMAT.md", "type": "checker"},
    {"id": "13-check-content", "entry": "13-check-content/THESIS_CHECK_CONTENT.md", "type": "checker"},
    {"id": "20-fix-references", "entry": "20-fix-references/THESIS_FIX_REFERENCES.md", "type": "fixer"},
    {"id": "21-fix-language-style", "entry": "21-fix-language-style/THESIS_FIX_LANGUAGE_STYLE.md", "type": "fixer"},
    {"id": "22-fix-format-structure", "entry": "22-fix-format-structure/THESIS_FIX_FORMAT_STRUCTURE.md", "type": "fixer"},
    {"id": "90-rules", "entry": "90-rules/THESIS_RULE_PACKS.md", "type": "ruleset", "runner": "90-rules/create_pack.py", "draft_runner": "90-rules/create_draft_pack.py"},
    {"id": "99-runner", "entry": "99-runner/README.md", "type": "runner"}
  ]
}
